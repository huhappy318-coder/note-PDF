{
  "manifest_version": 3,
  "name": "PageLock PDF Marker",
  "description": "Lightweight web highlighting and PDF export extension.",
  "version": "0.2.0",
  "action": {
    "default_title": "PageLock PDF Marker",
    "default_popup": "dist/popup.html",
    "default_icon": {
      "16": "dist/icons/icon-16.svg",
      "32": "dist/icons/icon-32.svg",
      "48": "dist/icons/icon-48.svg",
      "128": "dist/icons/icon-128.svg"
    }
  },
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage", "tabs", "downloads"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "dist/icons/icon-16.svg",
    "32": "dist/icons/icon-32.svg",
    "48": "dist/icons/icon-48.svg",
    "128": "dist/icons/icon-128.svg"
  },
  "options_page": "dist/options.html",
  "web_accessible_resources": [
    {
      "resources": ["dist/icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
